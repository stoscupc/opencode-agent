# Optional Jira environment variables for this setup repo.
# `make setup` can read these from this repo's local `.env` and persist them
# to `~/.config/opencode/jira.env` for the Jira tools. Missing values warn
# during setup but do not block sync.

# Jira custom tool configuration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
