# Optional local environment variables for custom tooling.
# If you plan to use the Jira tools, set these before running `make setup`
# or place them in a local `.env` file. Missing values warn during setup
# but do not block sync.

# Jira custom tool configuration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
